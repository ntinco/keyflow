{
  "version": 4,
  "purpose": "AI-first navigation map for rapid maintenance of keyflow.",
  "read-order": [
    "ai/health-check.summary.json",
    "ai/repo-map.json",
    "AGENTS.md",
    "README.md",
    "platforms/windows/keyflow.ahk",
    "platforms/windows/library/bootstrap.ahk",
    "platforms/windows/library/automation/sap-session.ahk",
    "platforms/windows/library/automation/sap.ahk"
  ],
  "ai-operating-guide": {
    "files": [
      "AGENTS.md",
      "README.md",
      "ai/repo-map.json",
      "ai/health-check.summary.json"
    ],
    "rule": "When routing, behavior, validation, or current evolution status changes, update this guide layer in the same cycle.",
    "current-focus": "Business-name-first SAP sessions, startup cleanup, and continued removal of dormant runtime surface."
  },
  "entrypoints": [
    {
      "id": "runtime",
      "path": "platforms/windows/keyflow.ahk",
      "role": "Main AutoHotkey entrypoint. Loads bootstrap and all hotkey aggregators."
    },
    {
      "id": "bootstrap",
      "path": "platforms/windows/library/bootstrap.ahk",
      "role": "Loads constants, services, and hotstring profiles."
    },
    {
      "id": "startup-host",
      "path": "platforms/windows/tools/startup/host-startup.ahk",
      "role": "Optional host launcher. Prepares local drives and portable links, then launches keyflow."
    },
    {
      "id": "startup-vmware",
      "path": "platforms/windows/tools/startup/vmware-startup.ahk",
      "role": "Optional VMware launcher. Mounts shared downloads and then launches keyflow."
    },
    {
      "id": "health-check",
      "path": "ai/health_check.py",
      "role": "Validation guard for includes, profiles, service wiring, forbidden legacy references, and guide drift."
    }
  ],
  "domains": [
    {
      "id": "sap-session",
      "path": "platforms/windows/library/automation/sap-session.ahk",
      "owns": [
        "KeePass-backed SAP session lookup",
        "entry field resolution",
        "session launch command assembly",
        "credential window filling"
      ]
    },
    {
      "id": "sap-automation",
      "path": "platforms/windows/library/automation/sap.ahk",
      "owns": [
        "SAP GUI automation",
        "Eclipse ABAP helpers",
        "tcode execution",
        "session reopen from project windows",
        "code-save and quick debug helpers"
      ]
    },
    {
      "id": "runtime-services",
      "path": "platforms/windows/library/automation/",
      "owns": [
        "13 registered services exposed as services.*",
        "dynamic, run, memory, launcher, windows, everything, snipaste, video, whatsapp, windowGroup, hotstring, hotkeyTracker"
      ]
    },
    {
      "id": "hotkeys",
      "path": "platforms/windows/hotkeys/",
      "owns": [
        "global triggers",
        "SAP GUI triggers",
        "SAP Eclipse triggers",
        "editor triggers",
        "domain triggers",
        "standalone layout script not loaded by default"
      ]
    },
    {
      "id": "catalogs",
      "path": "platforms/windows/data/",
      "owns": [
        "autocorrect catalog",
        "quick snippets",
        "SAP transaction shortcuts",
        "SAP transaction catalog",
        "ABAP snippets",
        "YMT commands",
        "startup and secret example contracts"
      ]
    },
    {
      "id": "startup",
      "path": "platforms/windows/tools/startup/",
      "owns": [
        "secondary launchers for host and VMware contexts",
        "drive mounting and portable app startup flow"
      ]
    },
    {
      "id": "ai-tooling",
      "path": "ai/",
      "owns": [
        "health_check.py",
        "health-check.summary.json",
        "health-check.json",
        "repo-map.json"
      ]
    }
  ],
  "runtime-api": [
    "dynamic",
    "everything",
    "hotkeyTracker",
    "hotstring",
    "launcher",
    "memory",
    "run",
    "sap",
    "snipaste",
    "video",
    "whatsapp",
    "windowGroup",
    "windows"
  ],
  "sap-session-entrypoints": [
    "services.sap.openPluzDevSession()",
    "services.sap.openPluzQasSession()",
    "services.sap.openPluzPrdSession()",
    "services.sap.openNamedSession(sessionName)"
  ],
  "hotstring-profile-add": [
    "1. Create data/<label>.json with format hotstring-items-v1 and items[].",
    "2. Add the profile to keyflowHotstringProfiles() in bootstrap.ahk.",
    "3. Run the health check and confirm item_count > 0.",
    "Modes: autocorrect, autocorrectImmediate, sapTransaction, ymtCommand, sapSession."
  ],
  "startup-config-sections": [
    "runtime-env",
    "sap-defaults",
    "sap-delays",
    "ui",
    "startup-host",
    "startup-vmware"
  ],
  "local-only-files": [
    "platforms/windows/data/local-secrets.ini",
    "platforms/windows/data/local-paths.ini",
    "platforms/windows/data/local-startup.ini",
    "platforms/windows/data/memory-vars.ini",
    "platforms/windows/data/rom.ini",
    "storage.db",
    "platforms/windows/storage.db"
  ],
  "standalone": [
    "platforms/windows/hotkeys/layouts/colemak-dh.ahk"
  ]
}
